#include <Wire.h>

#define SENSOR_ADDR 0x68

int16_t rawX, rawY, rawZ;

float accelX, accelY, accelZ;
float totalAccel;

int contadorPasos = 0;

bool flagPaso = false;

float limite = 1.2;

unsigned long tiempoUltimoPaso = 0;
unsigned long intervaloPaso = 300;

void setup() {

  Serial.begin(115200);

  Wire.begin();

  Wire.setClock(400000);

  Wire.beginTransmission(SENSOR_ADDR);

  Wire.write(0x6B);

  Wire.write(0x00);

  Wire.endTransmission();

  Serial.println("Contador de pasos iniciado");

}

void loop() {

  Wire.beginTransmission(SENSOR_ADDR);

  Wire.write(0x3B);

  Wire.endTransmission(false);

  Wire.requestFrom(SENSOR_ADDR, 6, true);

  rawX = Wire.read() << 8 | Wire.read();
  rawY = Wire.read() << 8 | Wire.read();
  rawZ = Wire.read() << 8 | Wire.read();

  accelX = rawX / 16384.0;
  accelY = rawY / 16384.0;
  accelZ = rawZ / 16384.0;

  totalAccel = sqrt(accelX * accelX + accelY * accelY + accelZ * accelZ);

  if (totalAccel > limite && !flagPaso) {

    if (millis() - tiempoUltimoPaso > intervaloPaso) {

      contadorPasos++;

      flagPaso = true;

      tiempoUltimoPaso = millis();

      Serial.print("Paso: ");

      Serial.println(contadorPasos);

    }

  }

  if (totalAccel < limite) {

    flagPaso = false;

  }
  delay(50);
}
