%% PUNTO 1.3: GIROSCOPIO CELULAR

m.Logging = 1;

disp('Capturando datos del giroscopio...');

pause(10);

m.Logging = 0;

[angVel, t_g] = angvellog(m);

pitch_gyro = cumtrapz(t_g, angVel(:,2)) * (180/pi);
roll_gyro = cumtrapz(t_g, angVel(:,1)) * (180/pi);

figure('Name', 'Punto 1.3 - Giroscopio Celular');

plot(t_g, pitch_gyro, 'r'); 
hold on;

plot(t_g, roll_gyro, 'b');

title('1.3: Pitch y Roll - Celular');

xlabel('Tiempo (s)');
ylabel('Grados (°)');

legend('Pitch', 'Roll');

grid on;
