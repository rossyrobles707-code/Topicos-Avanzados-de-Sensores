#include <Wire.h>
#include <Adafruit_BMP085.h>

Adafruit_BMP085 bmp;

// Temperatura base del frijol
float TB = 10.0;

// Variables
float temperatura;
float Tmax;
float Tmin;
float UC;
float UC_acumuladas = 0;

void setup() {
  Serial.begin(9600);
  Serial.println("SISTEMA DE FENOLOGIA DEL FRIJOL");
}

void loop() {

  // Leer temperatura del BMP180
  temperatura = bmp.readTemperature();

  // Simulacion de Tmax y Tmin
  Tmax = temperatura + 2;
  Tmin = temperatura - 2;

  // Formula de unidades calor
  UC = ((Tmax + Tmin) / 2.0) - TB;

  // Evitar negativos
  if (UC < 0) {
    UC = 0;
  }

  // Acumular UC
  UC_acumuladas = UC_acumuladas + UC;

  // Mostrar datos
  Serial.println("---------------------------");

  Serial.print("Temperatura actual: ");
  Serial.print(temperatura);
  Serial.println(" C");

  Serial.print("Temperatura maxima: ");
  Serial.print(Tmax);
  Serial.println(" C");

  Serial.print("Temperatura minima: ");
  Serial.print(Tmin);
  Serial.println(" C");

  Serial.print("Unidades calor del ciclo: ");
  Serial.println(UC);

  Serial.print("Unidades calor acumuladas: ");
  Serial.println(UC_acumuladas);

  // Etapa fenologica
  Serial.print("Etapa fenologica: ");

  if (UC_acumuladas < 12.89) {
    Serial.println("Germinacion");
  }

  else if (UC_acumuladas >= 12.89 && UC_acumuladas < 64.41) {
    Serial.println("Emergencia");
  }

  else if (UC_acumuladas >= 64.41 && UC_acumuladas < 91.33) {
    Serial.println("Formacion de guias");
  }

  else if (UC_acumuladas >= 91.33 && UC_acumuladas < 99.31) {
    Serial.println("Floracion");
  }

  else if (UC_acumuladas >= 99.31 && UC_acumuladas < 112.77) {
    Serial.println("Formacion de vaina");
  }

  else if (UC_acumuladas >= 112.77 && UC_acumuladas < 153.24) {
    Serial.println("Llenado de vainas");
  }

  else {
    Serial.println("Maduracion");
  }

  delay(5000);
}
